{
  "name": "markdown-blog-preview",
  "displayName": "Markdown Blog Preview",
  "description": "Markdown 转换微信公众号文章。Render markdown as inline html, and provide a variety of exquisite styles to facilitate publishing articles.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "when": "resourceLangId == markdown",
        "command": "mdbp.showView",
        "title": "预览文章",
        "icon": {
          "light": "./icon/markdown-preview-blog-theme-light.svg",
          "dark": "./icon/markdown-preview-blog-theme-dark.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == markdown",
          "command": "mdbp.showView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Blog Preview",
      "properties": {
        "mdbp.themeConfigFiles": {
          "type": "array",
          "default": [
            "themes/default.json"
          ],
          "items": {
            "type": "string"
          },
          "markdownDescription": "主题配置 JSON 文件路径列表（支持工作区相对路径与绝对路径）。例如：`[\"themes/wechat.json\", \"themes/minimal.json\"]`"
        }
      }
    }
  },
  "permissions": [
    "webview"
  ],
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext .ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.0.1",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "showdown": "^2.1.0"
  }
}
