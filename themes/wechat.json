{
	"name": "微信公众号",
	"contentFontSans": "-apple-system-font,BlinkMacSystemFont, Helvetica Neue, PingFang SC, Hiragino Sans GB, Microsoft YaHei UI, Microsoft YaHei, Arial, sans-serif",
	"contentFontSerif": "Optima-Regular, Optima, PingFangSC-light, PingFangTC-light, 'PingFang SC', Cambria, Cochin, Georgia, Times, 'Times New Roman', serif",
	"fixedCodeFont": "Consolas, 'Liberation Mono', Menlo, Courier, monospace",
	"contentStyle": {
		"text-align": "left",
		"color": "#3f3f3f",
		"line-height": "1.75"
	},
	"inlineCodeStyle": {
		"font-size": "90%",
		"color": "#d14",
		"background": "rgba(27,31,35,.05)",
		"padding": "3px 5px",
		"border-radius": "4px",
		"word-break": "break-all"
	},
	"elementStyles": {
		"h1": {
			"font-size": "1.2em",
			"text-align": "center",
			"font-weight": "bold",
			"display": "table",
			"margin": "2em auto 1em auto",
			"padding": "0 1em",
			"border-bottom": "1px solid rgb(248,57,41)"
		},
		"h2": {
			"font-weight": "bold",
			"font-size": "1.1em",
			"margin": "2em 8px 0.75em 0",
			"padding-bottom": ".1em",
			"padding-left": "8px",
			"border-left": "4px solid rgb(248,57,41)"
		},
		"h3": {
			"font-weight": "bold",
			"font-size": "1em",
			"margin": "2em 8px 0.5em 8px"
		},
		"p": {
			"margin": "1.5em 8px",
			"letter-spacing": "0.1em"
		},
		"blockquote": {
			"font-style": "normal",
			"border-left": "none",
			"padding": "1em",
			"border-radius": "4px",
			"color": "#FEEEED",
			"background": "rgba(27,31,35,.05)",
			"margin": "2em 8px"
		},
		"blockquote p": {
			"letter-spacing": "0.1em",
			"color": "rgb(80, 80, 80)",
			"font-family": "PingFangSC-light, PingFangTC-light, Open Sans, Helvetica Neue, sans-serif",
			"font-size": "1em",
			"display": "inline"
		},
		"pre": {
			"font-size": "80%",
			"overflow-x": "scroll",
			"color": "#333",
			"background": "rgb(247, 247, 247)",
			"border-radius": "2px",
			"padding": "10px",
			"line-height": "1.5",
			"border": "1px solid rgb(236,236,236)",
			"margin": "20px 0"
		},
		"img": {
			"border-radius": "4px",
			"display": "block",
			"margin": "0.5em auto",
			"width": "100%",
			"max-width": "100%",
      		"height": "auto"
		},
		"ol": {
			"margin-left": "0",
			"padding-left": "1em"
		},
		"ul": {
			"margin-left": "0",
			"padding-left": "1em",
			"list-style": "disc"
		},
		"figure": {
			"margin": "1.5em 8px"
		},
		"li": {
			"margin": "0.5em 8px"
		},
		"a": {
			"color": "#0080ff",
			"text-decoration": "none",
			"border-bottom": "1px solid #d1e9ff"
		},
		"strong": {
			"color": "#ff5f2e",
			"font-weight": "bold"
		},
		"table": {
			"border-collapse": "collapse",
			"text-align": "center",
			"margin": "1em 8px"
		},
		"thead": {
			"background": "rgba(0, 0, 0, 0.05)"
		},
		"td": {
			"font-size": "80%",
			"border": "1px solid #dfdfdf",
			"padding": "0.25em 0.5em"
		},
		"figcaption": {
			"text-align": "center",
			"color": "#888",
			"font-size": "0.8em"
		},
		"[data-mdbp-ref-sup]": {
			"font-size": "75%",
			"opacity": "0.75",
			"margin-left": "0.2em"
		},
		"[data-mdbp-references-title]": {
			"text-align": "left",
			"color": "#3f3f3f",
			"line-height": "1.75",
			"font-size": "1em",
			"font-weight": "bold",
			"margin": "2em 8px 0.5em 8px"
		},
		"[data-mdbp-references-list]": {
			"margin": "0.5em 8px",
			"letter-spacing": "0.02em",
			"font-size": "80%"
		},
		"[data-mdbp-references-index]": {
			"font-size": "90%",
			"opacity": "0.6",
			"font-style": "normal"
		},
		"[data-mdbp-references-url]": {
			"word-break": "break-all",
			"font-size": "90%"
		}
	}
}
